# =============================================================
# n8n Core Configuration
# =============================================================

# REQUIRED: Random string used to encrypt credentials in DB
# Generate one: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_generate_a_random_32char_string

# Basic auth to protect your n8n instance
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password

# Public URL where n8n is accessible (Railway sets this automatically)
# N8N_HOST=your-app.up.railway.app
# N8N_PORT=5678
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://your-app.up.railway.app/

# =============================================================
# Database — Railway PostgreSQL (auto-filled by Railway if you
# attach a Postgres plugin; otherwise fill manually)
# =============================================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=your_postgres_host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=railway
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_postgres_password

# =============================================================
# n8n Workflow Variables
# (Set these in n8n UI: Settings → Variables, OR as env vars)
# =============================================================

# Your Google Sheets document ID (the long ID in the Sheets URL)
# Example URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_DOC_ID=your_google_sheets_document_id

# =============================================================
# API Keys — set these as CREDENTIALS inside the n8n UI
# (n8n encrypts and stores them in DB, NOT in the workflow JSON)
# =============================================================

# Apify API Token → n8n UI: Credentials → New → Apify
# APIFY_API_TOKEN=apify_api_xxxxxxxxxxxx

# Google Gemini API Key → n8n UI: Credentials → New → Google Gemini(PaLM) API
# GOOGLE_GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxx

# Google Sheets OAuth2 → n8n UI: Credentials → New → Google Sheets OAuth2 API
# (OAuth — connect via browser, no key to paste)
